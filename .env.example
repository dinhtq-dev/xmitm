# XMITM configuration

# Auth store path (optional). Mac dinh: data/auth-store.json, fallback ./auth-store.json neu data/ khong ghi duoc
# AUTH_STORE_PATH=./auth-store.json

# OAuth redirect base (no trailing slash). Default: http://127.0.0.1:3000
OAUTH_REDIRECT_BASE=http://127.0.0.1:3000

# Google OAuth — Antigravity, Gemini CLI
# Create app: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://127.0.0.1:3000/api/admin/oauth/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth — Copilot
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Anthropic OAuth — Claude Code (optional, chua implement day du)
OAUTH_ANTHROPIC_CLIENT_ID=
OAUTH_ANTHROPIC_CLIENT_SECRET=

# Cursor OAuth (optional, chua ho tro)
OAUTH_CURSOR_CLIENT_ID=
OAUTH_CURSOR_CLIENT_SECRET=
